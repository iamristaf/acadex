<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="dashboard-container">

  <div class="dashboard-header">
    <div>
      <h1>🏫 <%= university.name %></h1>
      <p><%= university.city %>, <%= university.state %></p>
    </div>
    <a href="/university/logout" class="btn btn-outline btn-sm"
       style="color:#ef4444; border-color:#ef4444;">Logout</a>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num"><%= students.length %></div>
      <div class="stat-label">Students</div>
    </div>
    <div class="stat-card">
      <div class="stat-num"><%= teachers.length %></div>
      <div class="stat-label">Teachers</div>
    </div>
    <div class="stat-card">
      <div class="stat-num"><%= notes.length %></div>
      <div class="stat-label">Notes</div>
    </div>
    <div class="stat-card">
      <div class="stat-num"><%= notes.reduce((s,n) => s + n.views, 0) %></div>
      <div class="stat-label">Total Views</div>
    </div>
  </div>

  <!-- Teachers -->
  <div class="section">
    <h2>👨‍🏫 Teachers (<%= teachers.length %>)</h2>
    <% if (teachers.length === 0) { %>
      <p class="empty-msg">No teachers registered yet.</p>
    <% } else { %>
      <table class="mgmt-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Dept</th>
            <th>Emp ID</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% teachers.forEach(t => { %>
            <tr class="<%= t.isBanned ? 'row-banned' : '' %>">
              <td style="display:flex; align-items:center; gap:8px;">
                <% if (t.profilePhoto) { %>
                  <img src="<%= t.profilePhoto %>" style="width:32px; height:32px;
                       border-radius:50%; object-fit:cover;">
                <% } else { %>
                  <span style="font-size:24px;">👨‍🏫</span>
                <% } %>
                <%= t.name %>
                <% if (t.isVerified) { %>
                  <%- include('partials/verified-badge', { role: 'teacher' }) %>
                <% } %>
              </td>
              <td><%= t.email %></td>
              <td><%= t.department || '—' %></td>
              <td><%= t.employeeId || '—' %></td>
              <td>
                <% if (t.isBanned) { %>
                  <span class="status-badge banned">Banned</span>
                <% } else if (t.isVerified) { %>
                  <span class="status-badge verified">Verified</span>
                <% } else { %>
                  <span class="status-badge pending">Pending</span>
                <% } %>
              </td>
              <td class="action-btns">
                <% if (!t.isVerified && !t.isBanned) { %>
                  <form action="/university/verify/<%= t._id %>" method="POST" style="display:inline">
                    <button class="btn-verify">Verify</button>
                  </form>
                <% } %>
                <% if (t.isVerified) { %>
                  <form action="/university/unverify/<%= t._id %>" method="POST" style="display:inline">
                    <button class="btn-warn">Unverify</button>
                  </form>
                <% } %>
                <% if (!t.isBanned) { %>
                  <form action="/university/ban/<%= t._id %>" method="POST" style="display:inline"
                        onsubmit="return confirmBan(this)">
                    <input type="hidden" name="reason" value="Banned by university admin">
                    <button class="btn-danger">Ban</button>
                  </form>
                <% } else { %>
                  <form action="/university/unban/<%= t._id %>" method="POST" style="display:inline">
                    <button class="btn-verify">Unban</button>
                  </form>
                <% } %>
                <form action="/university/remove/<%= t._id %>" method="POST" style="display:inline"
                      onsubmit="return confirm('Remove this teacher from your university?')">
                  <button class="btn-danger">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- Students -->
  <div class="section">
    <h2>🎓 Students (<%= students.length %>)</h2>
    <% if (students.length === 0) { %>
      <p class="empty-msg">No students registered yet.</p>
    <% } else { %>
      <table class="mgmt-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Joined</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(s => { %>
            <tr class="<%= s.isBanned ? 'row-banned' : '' %>">
              <td style="display:flex; align-items:center; gap:8px;">
                <% if (s.profilePhoto) { %>
                  <img src="<%= s.profilePhoto %>" style="width:32px; height:32px;
                       border-radius:50%; object-fit:cover;">
                <% } else { %>
                  <span style="font-size:22px;">🎓</span>
                <% } %>
                <%= s.name %>
                <% if (s.isDualVerified) { %>
  <%- include('partials/verified-badge', { role: 'dual' }) %>
<% } else if (s.isPurpleVerified) { %>
  <%- include('partials/verified-badge', { role: 'purple' }) %>
<% } else if (s.isVerified) { %>
  <%- include('partials/verified-badge', { role: 'student' }) %>
<% } %>
              </td>
              <td><%= s.email %></td>
              <td><%= s.createdAt.toDateString() %></td>
              <td>
                <% if (s.isBanned) { %>
                  <span class="status-badge banned">Banned</span>
                <% } else if (s.isVerified) { %>
                  <span class="status-badge verified">Verified</span>
                <% } else { %>
                  <span class="status-badge pending">Pending</span>
                <% } %>
              </td>
              <td class="action-btns">
                <% if (!s.isVerified && !s.isBanned) { %>
                  <form action="/university/verify/<%= s._id %>" method="POST" style="display:inline">
                    <button class="btn-verify">Verify</button>
                  </form>
                <% } %>
                <% if (s.isVerified) { %>
                  <form action="/university/unverify/<%= s._id %>" method="POST" style="display:inline">
                    <button class="btn-warn">Unverify</button>
                  </form>
                <% } %>
                <% if (!s.isBanned) { %>
                  <form action="/university/ban/<%= s._id %>" method="POST" style="display:inline"
                        onsubmit="return confirmBan(this)">
                    <input type="hidden" name="reason" value="Banned by university admin">
                    <button class="btn-danger">Ban</button>
                  </form>
                <% } else { %>
                  <form action="/university/unban/<%= s._id %>" method="POST" style="display:inline">
                    <button class="btn-verify">Unban</button>
                  </form>
                <% } %>
                <form action="/university/remove/<%= s._id %>" method="POST" style="display:inline"
                      onsubmit="return confirm('Remove this student from your university?')">
                  <button class="btn-danger">Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- Notes -->
  <div class="section">
    <h2>📄 University Notes (<%= notes.length %>)</h2>
    <% if (notes.length === 0) { %>
      <p class="empty-msg">No notes uploaded yet.</p>
    <% } else { %>
      <div class="notes-grid">
        <% notes.forEach(note => { %>
          <div class="note-card">
            <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
              <span class="badge badge-<%= note.type.toLowerCase() %>"><%= note.type %></span>
              <% if (note.isRestricted) { %>
                <span class="badge-restricted">🔒 University Only</span>
              <% } %>
            </div>
            <h3 class="note-title"><%= note.title %></h3>
            <p class="note-meta"><%= note.subject %> • Sem <%= note.semester %></p>
            <p class="note-meta">👤 <%= note.uploader ? note.uploader.name : 'Unknown' %></p>
            <p class="note-views">👁 <%= note.views %> views</p>
            <div class="note-actions">
              <a href="/notes/view/<%= note._id %>" class="btn btn-primary btn-sm"
                 style="color:#fff !important;">View</a>
              <button class="btn btn-danger btn-sm"
                      onclick="showDeleteModal('<%= note._id %>',
                      '<%= note.title.replace(/'/g, "\\'") %>')">
                Remove
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</div>

<!-- Delete Modal -->
<div id="delete-modal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <h3>🗑️ Remove Note</h3>
    <p id="modal-note-name" style="color:#64748b; margin:8px 0 16px; font-size:14px;"></p>
    <div class="form-group">
      <label>Reason for removal <span style="color:#dc2626">*</span></label>
      <input type="text" id="delete-reason" required
             placeholder="e.g. Incorrect content, spam, copyright issue...">
    </div>
    <form id="delete-form" method="POST">
      <input type="hidden" name="reason" id="delete-reason-hidden">
      <div style="display:flex; gap:10px; margin-top:16px;">
        <button type="submit" class="btn btn-danger btn-full"
                onclick="document.getElementById('delete-reason-hidden').value =
                         document.getElementById('delete-reason').value">
          Confirm Remove
        </button>
        <button type="button" class="btn btn-outline btn-full"
                onclick="closeModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function showDeleteModal(noteId, noteTitle) {
  document.getElementById('modal-note-name').textContent = '"' + noteTitle + '"';
  document.getElementById('delete-form').action = '/notes/moderate-delete/' + noteId;
  document.getElementById('delete-reason').value = '';
  document.getElementById('delete-modal').style.display = 'flex';
}
function closeModal() {
  document.getElementById('delete-modal').style.display = 'none';
}
document.getElementById('delete-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

function confirmBan(form) {
  const reason = prompt('Enter ban reason (optional):');
  if (reason !== null) {
    form.querySelector('[name="reason"]').value = reason || 'Banned by university admin';
    return true;
  }
  return false;
}
</script>

<%- include('partials/footer') %>