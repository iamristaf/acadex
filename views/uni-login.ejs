<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <h2>University Login</h2>
    <p class="auth-sub">Login to manage your university's notes portal.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/university/login" method="POST">
      <div class="form-group">
        <label>Official Email</label>
        <input type="email" name="email" placeholder="admin@university.edu" required />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn btn-primary btn-full">Login</button>
    </form>

    <p class="auth-footer">Not registered yet? <a href="/university/register">Register University</a></p>
  </div>
</div>

<%- include('partials/footer') %>