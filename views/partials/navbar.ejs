</a>
        <a href="/university/logout" class="nav-logout">
          <i data-lucide="log-out"></i> Logout
        </a>

      <% } else if (locals.currentUser) { %>
        <a href="/notes/browse">
          <i data-lucide="layout-grid"></i> Browse
        </a>
        <a href="/notes/upload">
          <i data-lucide="upload"></i> Upload
        </a>
        <a href="/dashboard">
          <i data-lucide="layout-dashboard"></i> Dashboard
        </a>
        <a href="/contact">
  <i data-lucide="mail"></i> Contact
</a>
        <a href="/profile/<%= currentUser._id %>" class="nav-profile-link">
          <% if (currentUser.profilePhoto) { %>
            <img src="<%= currentUser.profilePhoto %>" class="nav-avatar" alt="Profile">
          <% } else { %>
            <span class="nav-avatar-placeholder">
              <%= currentUser.role === 'teacher' ? '👨‍🏫' : '🎓' %>
            </span>
          <% } %>
          <span><%= currentUser.name.split(' ')[0] %></span>
