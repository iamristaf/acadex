    <i data-lucide="shield"></i> Admin Panel
  </a>
  <a href="/contact">
  <i data-lucide="mail"></i> Contact
</a>
  <a href="/admin/logout" class="nav-logout">
    <i data-lucide="log-out"></i> Logout
  </a>

      <% } else if (locals.currentUniversity) { %>
        <a href="/notes/browse">
          <i data-lucide="layout-grid"></i> Browse
        </a>
        <a href="/university/dashboard">
          <i data-lucide="layout-dashboard"></i> Dashboard
        </a>
        <a href="/contact">
