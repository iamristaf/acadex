      <% } else { %>
        <a href="/notes/browse">
          <i data-lucide="layout-grid"></i> Browse
        </a>
        <a href="/login">
          <i data-lucide="log-in"></i> Login
        </a>
        <a href="/register">
          <i data-lucide="user-plus"></i> Register
        </a>
        <a href="/contact">
  <i data-lucide="mail"></i> Contact
</a>
        <a href="/university/login">
