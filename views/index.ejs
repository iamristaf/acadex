<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="hero">
  <div class="hero-content">
    <h1>Share Notes.<br>Learn Together.</h1>
    <p>Access notes, books, and PYQs from students across universities — all in one place.</p>
    <div class="hero-buttons">
      <a href="/notes/browse" class="btn btn-primary">Browse Notes</a>
      <a href="/register" class="btn btn-outline">Get Started</a>
    </div>
  </div>
</section>

<section class="features">
  <div class="features-grid">
    <div class="feature-card">
      <span>🏫</span>
      <h3>Multi-University</h3>
      <p>Access notes from students across different universities in one place.</p>
    </div>
    <div class="feature-card">
      <span>📄</span>
      <h3>Notes & PYQs</h3>
      <p>Find handwritten notes, books, previous year questions and more.</p>
    </div>
    <div class="feature-card">
      <span>👤</span>
      <h3>Independent Access</h3>
      <p>Even if your university isn't registered, you can still access and share notes.</p>
    </div>
    <div class="feature-card">
      <span>🔒</span>
      <h3>View Only</h3>
      <p>Notes are viewable online only — keeping content safe and organized.</p>
    </div>
  </div>
</section>

<section class="cta">
  <h2>Is your university not registered yet?</h2>
  <p>Register your university and let your students start sharing today.</p>
  <a href="/university/register" class="btn btn-primary">Register University</a>
</section>

<%- include('partials/footer') %>