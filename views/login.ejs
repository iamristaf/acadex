<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="auth-container">
  <div class="auth-card">
    <h2>Student Login</h2>
    <p class="auth-sub">Welcome back! Login to your account.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="you@example.com" required />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn btn-primary btn-full">Login</button>
    </form>

    <p class="auth-footer">Don't have an account? <a href="/register">Register here</a></p>
    <p class="auth-footer">University login? <a href="/university/login">Click here</a></p>
  </div>
</div>

<%- include('partials/footer') %>